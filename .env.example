# Copy to .env.local for local development.
# On Vercel: Project → Settings → Environment Variables (all environments).

# --- Required ---
OPENAI_API_KEY=

# --- Daily email digest ---
AUTO_REPORT_EMAIL=you@example.com
AUTO_REPORT_FREQUENCY=daily

# Resend (https://resend.com)
# Sandbox sender only delivers to your Resend signup email until you verify a domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Vercel Cron (required in production for scheduled digests) ---
# Generate: openssl rand -hex 32
# Vercel automatically sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Hacker News API courtesy limits ---
HN_RATE_LIMIT_PER_HOUR=8000
HN_MIN_REQUEST_INTERVAL_MS=250
HN_MAX_REQUESTS_PER_RUN=60
MIN_TRACTION_SCORE=20
MIN_THEME_TRACTION_SCORE=40

# --- Cron schedule (UTC) ---
# Configured in vercel.json, not here. Default: 0 13 * * * (~8-9 AM US Eastern)
# Hobby plan: max once per day. See README.md for Vercel limits.
